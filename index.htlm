<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ma Boutique</title>
<link rel="stylesheet" href="style.css">
</head>
<body>

<header>
    <h2>Ma Boutique</h2>
    <nav>
        <a href="index.html">Accueil</a>
        <a href="panier.html">Panier 🛒 <span id="compteur">0</span></a>
    </nav>
</header>

<section class="hero">

    <!-- 🌊 VAGUE HAUT -->
    <div class="wave wave-top">
        <svg viewBox="0 0 1440 320" preserveAspectRatio="none">
            <path fill="#242424"
                   d="M0,200L80,120C160,40,320,60,480,90C640,120,800,180,960,200C1120,220,1280,180,1360,140L1440,100L1440,0L0,0Z">
            </path>
        </svg>
    </div>

    <div class="hero-content">
        <h1>Freshly Roasted Coffee</h1>
        <p>Le meilleur café torréfié</p>
        <button onclick="ajouterAuPanierTest()">Tester le panier</button>
    </div>

    <!-- 🌊 VAGUE BAS -->
    <div class="wave wave-bottom">
        <svg viewBox="0 0 1440 320" preserveAspectRatio="none">
             <path fill="#242424"
                   d="M0,180L80,120C160,80,320,40,480,60C640,80,800,120,960,140C1120,160,1280,120,1360,100L1440,80L1440,320L0,320Z">
            </path>
        </svg>
    </div>

</section>

<section class="content">
    <h2>Nos produits arrivent bientôt...</h2>
</section>

<script src="script.js"></script>
</body>
</html>
